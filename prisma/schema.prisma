datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Document {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String   @default("日常") // "日常", "需求"
  project   String?  // Nullable project name, e.g. "个人网站"
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
