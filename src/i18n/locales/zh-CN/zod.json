{
  "zod": {
    "custom": "{field}校验未通过",
    "default": "{field}校验未通过",
    "exact": {
      "array": "{field}数量必须等于 {minimum}",
      "date": "{field}必须等于指定时间",
      "number": "{field}必须等于 {minimum}",
      "set": "{field}数量必须等于 {minimum}",
      "string": "{field}必须为 {minimum} 个字符"
    },
    "field": "字段",
    "invalidDate": "{field}不是有效日期",
    "invalidEnum": "请选择有效的{field}",
    "invalidString": {
      "default": "{field}格式不正确",
      "email": "{field}不是有效邮箱",
      "url": "{field}不是有效链接",
      "uuid": "{field}不是有效 UUID"
    },
    "invalidType": "{field}格式不正确",
    "required": "{field}为必填项",
    "tooBig": {
      "array": "{field}数量不能超过 {maximum}",
      "date": "{field}不能晚于指定时间",
      "number": "{field}不能大于 {maximum}",
      "set": "{field}数量不能超过 {maximum}",
      "string": "{field}不能超过 {maximum} 个字符"
    },
    "tooSmall": {
      "array": "{field}数量不能少于 {minimum}",
      "date": "{field}不能早于指定时间",
      "number": "{field}不能小于 {minimum}",
      "set": "{field}数量不能少于 {minimum}",
      "string": "{field}不能少于 {minimum} 个字符"
    }
  }
}
