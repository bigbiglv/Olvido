{
  "name": "olvido",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/index.js",
  "scripts": {
    "dev": "vite",
    "build": "pnpm type-check && vite build && electron-builder",
    "build:only": "pnpm type-check && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.5.4",
    "@milkdown/kit": "^7.5.4",
    "@milkdown/vue": "^7.5.4",
    "@prisma/client": "^5.16.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.7",
    "sortablejs": "^1.15.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.34",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "prettier": "^3.8.3",
    "prisma": "^5.16.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.8"
  },
  "build": {
    "appId": "com.olvido.app",
    "productName": "Olvido",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/@prisma/engines/**/*",
      "**/node_modules/.prisma/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Olvido",
      "createDesktopShortcut": true
    }
  }
}
